LLM_MODEL=us.anthropic.claude-opus-4-6-v1
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=800
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Credentials are resolved via the default AWS credential chain:
# IAM role (EC2/ECS), ~/.aws/credentials, or AWS_ACCESS_KEY_ID env var
AWS_REGION=us-east-1

MAX_DOCUMENT_CHARS=100000
MAX_QUESTION_CHARS=2000
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=3
MIN_RETRIEVAL_SCORE=0.05
MAX_RETRIEVED_CONTEXT_CHARS=8000
MAX_TOOL_CALLS=3

PII_MODE=redact_before_llm
ENABLE_CONTENT_LOGGING=false

ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

GIT_COMMIT=unknown-local
APP_VERSION=0.1.0
TESTING=false
